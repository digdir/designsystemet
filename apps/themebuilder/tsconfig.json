{
  "extends": "../../tsconfig.base.json",
  "include": [
    "**/*",
    "**/.server/**/*",
    "**/.client/**/*",
    ".react-router/types/**/*",
    "**/*.css"
  ],
  "exclude": ["**/dist/**/*"],
  "compilerOptions": {
    "types": ["node", "vite/client", "../../internal/digdir/themes/types.d.ts"],
    "module": "ES2022",
    "rootDirs": [".", "./.react-router/types"],
    "paths": {
      "~/*": ["./app/*"]
    },
    "verbatimModuleSyntax": true
  }
}
