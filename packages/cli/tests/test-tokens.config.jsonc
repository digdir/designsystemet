{
  "$schema": "../dist/config.schema.json",
  "outDir": "tests/config/design-tokens",
  "clean": true,
  "themes": {
    "some-org": {
      "colors": {
        "dominant": "#0062BA",
        "complimentary": "#94237C",
        "hyphen-color": "#F45F63",
        "double-hyphen-color": "#E5AA20",
        "neutral": "#303030"
      },
      "typography": {
        "fontFamily": "Inter"
      },
      "borderRadius": 8,
      "overrides": {
        "colors": {
          "dominant": {
            "background-default": {
              "light": "#ff0000",
              "dark": "#000fff"
            },
            "background-tinted": {
              "light": "#f0ff00",
              "dark": "#ff00ff"
            }
          },
          "danger": {
            "background-default": {
              "light": "#0000ff",
              "dark": "#0000ff"
            }
          }
        },
        "severity": {
          "danger": "#ff00ff"
        },
        "linkVisited": {
          "light": "#ff1234",
          "dark": "#1234ff"
        },
        "focus": {
          "inner": {
            "light": "#00ff00",
            "dark": "#00ffff"
          },
          "outer": {
            "light": "#ffff00",
            "dark": "#ff00aa"
          }
        }
      }
    },
    "other-org": {
      "colors": {
        "dominant": "#ffaaaa",
        "complimentary": "#00ff00",
        "hyphen-color": "#abcdef",
        "double-hyphen-color": "#123456",
        "neutral": "#c05030"
      },
      "typography": {
        "fontFamily": "Roboto"
      },
      "borderRadius": 99
    }
  }
}
