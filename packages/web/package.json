{
  "name": "@digdir/designsystemet-web",
  "type": "module",
  "version": "1.13.1",
  "description": "Javascript for Designsystemet",
  "author": "Designsystemet team",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/digdir/designsystemet.git"
  },
  "homepage": "https://github.com/digdir/designsystemet/tree/main/packages/web",
  "license": "MIT",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./custom-elements.json": "./dist/custom-elements.json",
    "./vscode.html-custom-data.json": "./dist/vscode.html-custom-data.json",
    "./ds-breadcrumbs": {
      "types": "./dist/index.d.ts",
      "import": "./dist/esm/breadcrumbs/breadcrumbs.js",
      "require": "./dist/cjs/breadcrumbs/breadcrumbs.js"
    },
    "./clickdelegatefor": {
      "types": "./dist/index.d.ts",
      "import": "./dist/esm/clickdelegatefor/clickdelegatefor.js",
      "require": "./dist/cjs/clickdelegatefor/clickdelegatefor.js"
    },
    "./dialog": {
      "types": "./dist/index.d.ts",
      "import": "./dist/esm/dialog/dialog.js",
      "require": "./dist/cjs/dialog/dialog.js"
    },
    "./ds-error-summary": {
      "types": "./dist/index.d.ts",
      "import": "./dist/esm/error-summary/error-summary.js",
      "require": "./dist/cjs/error-summary/error-summary.js"
    },
    "./ds-field": {
      "types": "./dist/index.d.ts",
      "import": "./dist/esm/field/field.js",
      "require": "./dist/cjs/field/field.js"
    },
    "./fieldset": {
      "types": "./dist/index.d.ts",
      "import": "./dist/esm/fieldset/fieldset.js",
      "require": "./dist/cjs/fieldset/fieldset.js"
    },
    "./ds-pagination": {
      "types": "./dist/index.d.ts",
      "import": "./dist/esm/pagination/pagination.js",
      "require": "./dist/cjs/pagination/pagination.js"
    },
    "./popover": {
      "types": "./dist/index.d.ts",
      "import": "./dist/esm/popover/popover.js",
      "require": "./dist/cjs/popover/popover.js"
    },
    "./readonly": {
      "types": "./dist/index.d.ts",
      "import": "./dist/esm/readonly/readonly.js",
      "require": "./dist/cjs/readonly/readonly.js"
    },
    "./ds-suggestion": {
      "types": "./dist/index.d.ts",
      "import": "./dist/esm/suggestion/suggestion.js",
      "require": "./dist/cjs/suggestion/suggestion.js"
    },
    "./ds-tabs": {
      "types": "./dist/index.d.ts",
      "import": "./dist/esm/tabs/tabs.js",
      "require": "./dist/cjs/tabs/tabs.js"
    },
    "./toggle-group": {
      "types": "./dist/index.d.ts",
      "import": "./dist/esm/toggle-group/toggle-group.js",
      "require": "./dist/cjs/toggle-group/toggle-group.js"
    },
    "./tooltip": {
      "types": "./dist/index.d.ts",
      "import": "./dist/esm/tooltip/tooltip.js",
      "require": "./dist/cjs/tooltip/tooltip.js"
    }
  },
  "files": [
    "dist/**"
  ],
  "scripts": {
    "start": "vite --config=./vite.config.ts --port=5174",
    "build": "rimraf dist && tsup && rolldown -c && cem analyze",
    "test": "vitest --config=vitest.config.ts"
  },
  "customElements": "dist/custom-elements.json",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "@u-elements/u-combobox": "^1.0.7",
    "@u-elements/u-datalist": "^1.1.0",
    "@u-elements/u-details": "^0.2.2",
    "@u-elements/u-progress": "^0.0.7",
    "@u-elements/u-tabs": "^0.1.2"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "0.11.0",
    "@testing-library/dom": "10.4.1",
    "@vitest/browser-playwright": "4.1.2",
    "custom-element-vs-code-integration": "1.5.0",
    "invokers-polyfill": "1.0.2",
    "rimraf": "6.1.3",
    "rolldown": "1.0.0-rc.9",
    "tsup": "8.5.1",
    "vite": "7.3.2",
    "vitest": "4.1.2"
  }
}