{
  "name": "root",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.34.3+sha512.f2c531b08829d7be7f03c90addc266615f9c5477463e4bf1d275cb263ce9ea57cf0d5599110d94649a9bb3fed9f0b5efcea74a7016b61532a24cb9ad87860c1d",
  "engines": {
    "node": ">=24.16.0",
    "runtime": {
      "name": "node",
      "version": "24.16.0",
      "onFail": "download"
    }
  },
  "scripts": {
    "test": "vitest",
    "test:cli": "pnpm --filter @digdir/designsystemet test --verbose",
    "test:web": "pnpm --filter @digdir/designsystemet-web test",
    "test:storybook": "pnpm --filter @web/storybook test-storybook",
    "test:coverage": "vitest run --coverage",
    "test:www-links": "pnpm node scripts/search-broken-links.js",
    "storybook": "pnpm --filter @web/storybook dev",
    "www": "pnpm --filter @web/www dev",
    "web": "pnpm --filter @digdir/designsystemet-web start",
    "themebuilder": "pnpm --filter @web/themebuilder dev",
    "build": "pnpm --filter @digdir/* build",
    "build:all": "pnpm -r build",
    "build:react": "pnpm --filter @digdir/designsystemet-react build",
    "build:css": "pnpm --filter @digdir/designsystemet-css build",
    "build:cli": "pnpm --filter @digdir/designsystemet build",
    "build:web": "pnpm --filter @digdir/designsystemet-web build",
    "build:types": "pnpm --filter @digdir/designsystemet-types build",
    "build:storybook": "pnpm --filter @web/storybook build",
    "build:www": "pnpm --filter @web/www build",
    "build:themebuilder": "pnpm --filter @web/themebuilder build",
    "types": "pnpm -r types",
    "types:react": "pnpm --filter @digdir/designsystemet-react types",
    "version-packages": "changeset version && node scripts/sync-changelogs.js && pnpm build:types && pnpm build:cli && node scripts/sync-cli-schema.js && pnpm update:theme && pnpm update:theme-digdir && git add . && git commit -m \"sync www changelogs, schema and tokens\" || true",
    "publish-packages": "pnpm build && changeset publish",
    "chromatic": "pnpm --filter @web/storybook chromatic",
    "update:theme-digdir": "pnpm --filter @internal/digdir update:theme-digdir",
    "update:theme": "designsystemet tokens create --config designsystemet.config.json && pnpm --filter @digdir/designsystemet-css build:theme",
    "update:preview-tokens": "pnpm --filter @digdir/designsystemet run update:preview-tokens"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@changesets/cli": "2.31.0",
    "@changesets/get-github-info": "^0.8.0",
    "@changesets/types": "^6.1.0",
    "@digdir/designsystemet": "workspace:^",
    "@testing-library/jest-dom": "6.9.1",
    "@types/node": "24.13.2",
    "@vitejs/plugin-react-swc": "4.3.1",
    "@vitest/browser-playwright": "4.1.8",
    "@vitest/coverage-v8": "4.1.8",
    "chromatic": "17.7.1",
    "typescript": "5.9.3",
    "typescript-plugin-css-modules": "5.2.0",
    "vite": "7.3.5",
    "vitest": "4.1.8"
  },
  "dependencies": {}
}
